class Solution:
    def isValid(self, s: str) -> bool:
        s={")":"(","]":"[","}":"{"}
        stack=[]
        for i in s:
            if i in "({[":
                stack.append(i)
            else:
                if not stack:
                    return False
                else:
                    if (stack and stack[-1]==s[i]):
                        stack.pop()
                    else:
                        return False
        return not stack
                
        
