class Solution:
    def maxScore(self, cardPoints: List[int], k: int) -> int:
        leftsum=sum(cardPoints[:k])
        maxsum=leftsum
        rightsum=0
        l=0
        for i in range(1,k+1):
            leftsum-=cardPoints[k-i]
            rightsum+=cardPoints[-i]
            summ =rightsum+leftsum
            maxsum=max(maxsum,summ)
        return maxsum
