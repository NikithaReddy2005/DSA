#Binary search
#t.c:O(log max(arr),s.c:O(1)

class Solution: 
    import math
    def minEatingSpeed(self, piles: List[int], h: int) -> int:
        left=1
        right=max(piles)
        while left < right:
            mid = left+(right-left)//2
            hrs=0
            for pile in piles:
                hrs+=math.ceil(pile/mid)
            if hrs <= h:
                right=mid
            else:
                left=mid+1
        return left
        
