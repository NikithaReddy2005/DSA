# recursive apporach : backtracking
class Solution:
    def subsets(self, nums: List[int]) -> List[List[int]]:
        res=[]
        def bt(ind,subset):
            res.append(subset[:])
            for i in range(ind,len(nums)):
                subset.append(nums[i])
                bt(i+1,subset)
                subset.pop()
        bt(0,[])
        return res
        
